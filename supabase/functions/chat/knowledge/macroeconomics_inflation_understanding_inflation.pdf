<style>

        .triangle-down {
            flex-basis: 100%;
            width: 50px;
            height: 30px;
            aspect-ratio: 1;
            clip-path: polygon(25% 0, 50% 75%, 75% 0%);
            position: absolute;
            top: calc(50% );
            /*left: calc(100%);*/
            background-color: white;
            z-index: 1;
        }
        .triangle-upp {
            flex-basis: 100%;
            width: 30px;
            height: 30px;
            aspect-ratio: 1;
            clip-path: polygon(25% 100%, 50% 75%, 75% 100%);
            position: absolute;
            top: calc(50% );
            /*left: calc(100%);*/
            background-color: white;
            z-index: 1;
        }
        .triangle-up::after {
            flex-basis: 100%;
            width: 45px;
            height: 25px;
            aspect-ratio: 1;
            clip-path: polygon(25% 100%, 50% 75%, 75% 100%);
            position: absolute;
            top: calc(50% );
            /*left: calc(100%);*/
            background-color: white;
            z-index: 1;
        }
